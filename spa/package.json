    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-router-devtools": "^6.2.0",
    "rimraf": "^6.1.3",
    "serve": "^14.2.4",
