    "dotenv": "^17.3.1",
    "intl-parse-accept-language": "^1.0.0",
    "isbot": "^5.1.37",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@lingui/babel-plugin-lingui-macro": "^5.9.4",
    "@lingui/cli": "^5.9.4",
    "@lingui/vite-plugin": "^5.9.4",
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
